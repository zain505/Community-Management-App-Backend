NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# MySQL for auth-service
DATABASE_URL=mysql://root:root@127.0.0.1:3306/auth_db

# JWT secrets must be long random strings (>= 32 chars)
JWT_ACCESS_SECRET=change-this-access-secret-to-a-long-random-string
JWT_REFRESH_SECRET=change-this-refresh-secret-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=10
